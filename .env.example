# ZENXHAT Configuration File
# Copy this to .env and add your API keys

# Optional: Shodan API Key
# Get it from: https://www.shodan.io/
SHODAN_API_KEY=

# Optional: Censys API Credentials
# Get it from: https://censys.io/
CENSYS_API_ID=
CENSYS_API_SECRET=

# Optional: VirusTotal API Key
# Get it from: https://www.virustotal.com/
VIRUSTOTAL_API_KEY=

# Optional: Hunter.io API Key (Email finding)
# Get it from: https://hunter.io/
HUNTER_API_KEY=

# Optional: AbuseIPDB API Key
# Get it from: https://www.abuseipdb.com/
ABUSEIPDB_API_KEY=

# Optional: EmailRep API Key
# Get it from: https://emailrep.io/
EMAILREP_API_KEY=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Rate limiting (requests per second)
RATE_LIMIT=2

# Timeout for requests (seconds)
REQUEST_TIMEOUT=10
